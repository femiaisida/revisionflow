# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to GitHub.

# Firebase (get from Firebase Console → Project Settings)
VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# Mistral AI — PRIMARY (free, no regional restrictions)
# Get your free key at https://console.mistral.ai
VITE_MISTRAL_API_KEY=your_mistral_key_here

# Gemini AI — FALLBACK (used if Mistral key is missing or fails)
# Get your free key at https://aistudio.google.com/app/apikey
VITE_GEMINI_API_KEY=your_gemini_key_here
